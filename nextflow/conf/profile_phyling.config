/*
 * PHYling profile: phyling.nf — multi-locus phylogenomics.
 *
 * Input FASTAs are read from input/pep/ or input/cds/ (populated by BFD.nf SETUP_INPUT).
 * Markersets are resolved from the shared BUSCO v12 lineages database; extracted directories
 * are used directly, versioned tarballs are extracted into phylogeny/markersets/ on first use.
 *
 * Override any param on the command line with --param value.
 */

params {
    // ── Input ──────────────────────────────────────────────────────────────────
    // Default sample sheet for phylogenomics (may be a curated subset of samples.csv).
    // Falls back to samples.csv if phylo.csv is absent — override with --samples.
    samples      = file("${launchDir}/phylo.csv").exists()
                       ? "${launchDir}/phylo.csv"
                       : "${launchDir}/samples.csv"

    pep_dir      = "${launchDir}/input/pep"
    cds_dir      = "${launchDir}/input/cds"

    // ── Sequence type ──────────────────────────────────────────────────────────
    // 'protein' (default) or 'cds'.  Selects input/pep or input/cds and passes
    // --seqtype pep/dna to phyling.
    seq_type     = 'protein'

    // ── Markersets ─────────────────────────────────────────────────────────────
    // Comma-separated list of BUSCO lineage names (no spaces).
    // Each runs as an independent parallel branch.
    // Available extracted lineages in markerset_db (check with: ls /srv/projects/db/BUSCO/v12/lineages/):
    //   fungi_odb12 (tarball only — extracted on first run)
    //   ascomycota_odb12, basidiomycota_odb12, mucoromycota_odb12
    //   agaricomycetes_odb12, dothideomycetes_odb12, sordariomycetes_odb12, ...
    markerset    = 'fungi_odb12'
    markerset_db = '/srv/projects/db/BUSCO/v12/lineages'

    // ── Tree building ──────────────────────────────────────────────────────────
    // tree_method: ft (FastTree, fast), iqtree (recommended), raxml
    tree_method  = 'iqtree'
    // top_n: number of top markers to retain after treeness/RCV filtering
    top_n        = 50

    // ── Output ─────────────────────────────────────────────────────────────────
    // Results land in phylo_outdir/{taxon_slug}/{seq_type}/{markerset}/
    // taxon_slug is derived automatically from --taxon (e.g. PHYLUM:Ascomycota → Ascomycota)
    // or 'all' when no taxon filter is applied.
    phylo_outdir = "${launchDir}/phylogeny"
}

workDir = "${launchDir}/work/phyling"

process {
    withLabel: 'setup' {
        cpus   = 1
        memory = '2 GB'
        time   = '30 min'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
        """
    }

    // phyling align: hmmsearch across all taxa × all HMM markers — heavy I/O and CPU.
    // Use highmem queue; allow generous walltime for large datasets (5000+ taxa).
    withLabel: 'phyling_align' {
        cpus   = 32
        memory = '256 GB'
        time   = '24 h'
        queue  = 'highmem'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load phyling
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    // phyling filter: per-locus FastTree for treeness/RCV — moderately parallel.
    withLabel: 'phyling_filter' {
        cpus   = 16
        memory = '32 GB'
        time   = '4 h'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load phyling
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    // phyling tree --concat --partition: concatenated ML tree.
    // IQ-TREE and RAxML-NG can be slow on large datasets; use epyc for long jobs.
    withLabel: 'phyling_tree' {
        cpus   = 32
        memory = '128 GB'
        time   = '48 h'
        queue  = 'epyc'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load phyling
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }
}

trace {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/phyling_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,rss,tag'
}
report {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/phyling_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/phyling_timeline.html"
    overwrite = true
}
