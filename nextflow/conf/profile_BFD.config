/*
 * BFD profile: BFD.nf (functional annotation) and
 * genome_seqstats.nf (sequence statistics) for annotated BFD genomes.
 */

params {
    pep_dir             = "${launchDir}/input/pep"
    cds_dir             = "${launchDir}/input/cds"
    gff_dir             = "${launchDir}/input/gff3"
    trna_dir            = "${launchDir}/input/trna"
    genome_dir          = "${launchDir}/input/dna"
    genome_annotation   = "${launchDir}/genome_annotation"
    tables              = "${launchDir}/tables"
    scripts             = "${launchDir}/scripts"
    outdir              = "${launchDir}/results/function"
    stats_outdir        = "${launchDir}/results/seqstats"
    genome_stats_outdir = "${launchDir}/results/genome_stats"

    run_setup     = true
    run_pfam      = true
    run_cazy      = true
    run_merops    = true
    run_signalp   = true
    run_tmhmm     = true
    run_targetp   = true
    run_idp       = true
    run_wolfpsort = true
    run_predgpi   = true

    pfam_nodes    = 1
    pfam_tasks    = 1

    run_aa_freq    = true
    run_codon_freq = true
    run_intergenic = true
    run_gene_stats = true
    run_chrom_info = true

    // Merge scope and skip controls.
    // merge_all=true  → MERGE collects ALL files from results/function/<tool>/,
    //                   not just those produced in this run (default).
    // merge_all=false → MERGE only sees outputs from the current run.
    // skip_merge=true → skip all MERGE_* steps (useful when only running new
    //                   species and deferring the merge to a later step).
    merge_all  = true
    skip_merge = false
}

workDir = "${launchDir}/work/functional"

process {
    withLabel: 'setup' {
        executor = 'local'
        cpus   = 1
        memory = '1 GB'
        time   = '30 min'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
        """
    }

    withLabel: 'pfam' {
        cpus           = 4
        memory         = '32 GB'
        time           = '8 h'
        queue          = 'highclock'
        clusterOptions = { params.pfam_tasks > 1
                            ? "-N ${params.pfam_nodes} -n ${params.pfam_tasks} -c 1"
                            : '-N 1 -n 1' }
        beforeScript   = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            if [ ${params.pfam_tasks} -gt 1 ]; then
                module load hmmer/3.4-mpi
            else
                module load hmmer/3.4
            fi
            module load db-pfam
            module load workspace/scratch
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'cazy' {
        cpus         = 16
        memory       = '8 GB'
        time         = '2 h'
        queue        = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load dbcanlight
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'merops' {
        cpus   = 8
        memory = '4 GB'
        time   = '2 h'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load db-merops/124
            module load ncbi-blast/2.16.0+
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'signalp' {
        cpus           = 8
        memory         = '64 GB'
        time           = '2 h'
        queue          = 'short_gpu'
        clusterOptions = '-N 1 -n 1 --gres=gpu:1'
        beforeScript   = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load signalp/6-gpu
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'tmhmm' {
        cpus   = 4
        memory = '8 GB'
        time   = '2 h'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load tmhmm
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'targetp' {
        cpus   = 8
        memory = '16 GB'
        time   = '4 h'
        queue  = 'epyc'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load targetp
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'idp' {
        cpus           = 4
        memory         = '48 GB'
        time           = '2 h'
        queue          = 'short_gpu'
        clusterOptions = '-N 1 -n 1 --gres=gpu:1'
        beforeScript   = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load aiupred
            module load biopython
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'wolfpsort' {
        cpus   = 4
        memory = '8 GB'
        time   = '2 h'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load wolfpsort
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'predgpi' {
        cpus         = 4
        memory       = '16 GB'
        time         = '4 h'
        queue        = 'epyc'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load predgpi
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'genestats' {
        cpus         = 1
        memory       = '8 GB'
        time         = '2 h'
        queue        = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load biopython
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    // Per-genome stat processes: tune individually where needed.
    withName: 'CALC_INTERGENIC' {
        memory = '16 GB'
        time   = '1 h'
    }
    withName: 'CALC_GENE_STATS' {
        cpus   = 2
        memory = '16 GB'
        time   = '2 h'
    }

    withLabel: 'seqstats' {
        cpus         = 2
        memory       = '8 GB'
        time         = '2 h'
        queue        = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load biopython
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'merge' {
        cpus         = 4
        memory       = '24 GB'
        time         = '2 h'
        queue        = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load biopython
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }
}

trace {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/BFD_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,rss,tag'
}
report {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/BFD_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/BFD_timeline.html"
    overwrite = true
}
