/*
 * funannotate profile: funannotate.nf genome prediction and annotation pipeline.
 *
 * SOURCE: ../../../1KFG/common_annotate/pipeline/nextflow/nextflow.config (funannotate profile)
 *         ../../../1KFG/common_annotate/pipeline/nextflow/funannotate.nf (params block)
 * Last synced: 2026-05-23
 * Changes vs source: params extracted from funannotate.nf and merged here;
 *                    workDir/cleanup/trace/report/timeline lifted from profile block.
 */

params {
    target               = "${launchDir}/genome_annotation"
    taxondb              = "/bigdata/stajichlab/shared/projects/1KFG/2026/NCBI_fungi/tmp/taxa/"
    proteins             = "${launchDir}/lib/swissprot_fungi.faa"
    source               = "/bigdata/stajichlab/shared/projects/1KFG/2026/NCBI_fungi/source/NCBI_ASM"
    seqcenter            = "NCBI"
    augustus_config      = "${launchDir}/lib/augustus/3.5/config"
    funannotate_db       = "/bigdata/stajichlab/shared/lib/funannotate_db"
    min_contig_len       = 2000
    clean_script         = "${launchDir}/scripts/clean_genome_fa.py"
    fastq_hdr_script     = "${launchDir}/scripts/fix_fastq_headers"
    sbt_template         = "${launchDir}/lib/template.sbt"
    debug                = false
    max_cpus             = 64
    suppress             = ""
    max_rnaseq_runs      = 4
    only_clean           = false
    run_sra_fetch        = true
    run_repeatmodeler    = false
    run_repeatmasker     = true
    repeatmasker_species = "fungi"
    run_update           = false
    run_annotate         = false
    run_antismash        = false
    rnaseq_data          = "${launchDir}/rnaseq_data"
    run_interpro         = false
    run_signalp          = false
    antismash_taxon      = "fungi"
    pasa_mysql           = true
    mariadb_sif          = "/bigdata/stajichlab/shared/lib/mariadb/mariadb.sif"
    mysql_datadir        = "/bigdata/stajichlab/jstajich/mysql/db"
    pasa_conf_dir        = "/rhome/jstajich/.pasa/pasa_conf/"
    max_intronlen        = 3000
    min_intronlen        = 10
}

workDir = "${launchDir}/work/funannotate"
cleanup = true

process {
    withName: 'SETUP_TAXONDB' {
        queue  = 'short'
        memory = '1 GB'
        time   = '30m'
        cpus   = 1
    }
    withName: 'GENOME_CLEAN' {
        queue          = 'highmem'
        memory         = '500 GB'
        time           = '2h'
        clusterOptions = '-N 1 -n 1 -w h04,h05,h06'
    }
    withName: 'SRA_FETCH' {
        errorStrategy = 'retry'
        maxRetries    = 2
        queue         = { task.attempt == 1 ? 'short' : 'epyc' }
        memory        = { task.attempt == 1 ? '48 GB' : '192 GB' }
        time          = { task.attempt == 1 ? '2h'    : '8h' }
        cpus          = 24
    }
    withName: 'REPEATMODELER_RUN' {
        queue  = 'epyc'
        cpus   = 16
        memory = '32 GB'
        time   = '72h'
    }
    withName: 'REPEATMASKER_RUN' {
        queue  = 'epyc'
        cpus   = 32
        memory = '24 GB'
        time   = '24h'
    }
    withName: 'RNASEQ_PREPARE' {
        queue      = 'epyc'
        cpus       = 16
        memory     = { task.attempt == 1 ? '96 GB' : (96 + (task.attempt - 1) * 48) + ' GB' }
        time       = '120h'
        maxRetries = 3
    }
    withName: 'FUNANNOTATE_TRAIN' {
        queue  = 'epyc'
	maxRetries = 3
        memory = { task.attempt == 1 ? '96 GB' : '192 GB' }
        time   = { task.attempt == 1 ? '72h' : '120h' }
        cpus   = { task.attempt == 1 ? 8 : 24 }
    }
    withName: 'FUNANNOTATE_PREDICT' {
        queue  = 'epyc'
        memory = '32 GB'
        time   = '72h'
        cpus   = 16
    }
    withName: 'SIGNALP_RUN' {
        queue          = 'exfab'
        cpus           = 16
        memory         = '64 GB'
        time           = '2h'
        clusterOptions = '--gres=gpu:1 -N 1 -n 1'
    }
    withName: 'INTERPROSCAN_RUN' {
        queue  = 'epyc'
        cpus   = 8
        memory = '32 GB'
        time   = '60h'
    }
    withName: 'ANTISMASH_RUN' {
        queue  = 'epyc'
        memory = '24 GB'
        time   = '8h'
    }
    withName: 'FUNANNOTATE_ANNOTATE' {
        queue  = 'epyc'
        memory = '64 GB'
        time   = '24h'
    }
}

trace {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/funannotate_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,rss,tag'
}
report {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/funannotate_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/funannotate_timeline.html"
    overwrite = true
}
