/*
 * comparative profile: comparative_genomics.nf clustering workflows.
 *
 * Organism selection (OR/UNION logic, then --ignore exclusion):
 *   --group  PATH  CSV with LOCUSTAG,GROUP columns
 *   --taxon  STR   Comma-separated RANK:VALUE pairs (e.g. CLASS:Dothideomycetes,ORDER:Hypocreales)
 *   --ignore PATH  One LOCUSTAG per line; excluded from the analysis
 *
 * Enable/disable sub-workflows:
 *   --run_mmseqs2     true/false  (default: true)
 *   --run_mcl         true/false  (default: true)
 *   --run_orthofinder true/false  (default: false)
 */

params {
    // Required
    project              = ''

    // Organism selection
    group                = ''
    ignore               = ''
    // taxon is defined in nextflow.config (shared param); override here if needed.

    // Input protein/CDS directories (symlinked into comparative/{project}/)
    pep_dir              = "${launchDir}/input/pep"
    cds_dir              = "${launchDir}/input/cds"

    // Output root
    outdir               = "${launchDir}/comparative"

    // Sub-workflow switches
    run_mmseqs2          = true
    run_mcl              = true
    run_orthofinder      = false

    // MMseqs2 parameters
    mmseqs_min_id        = 0.30
    mmseqs_cov           = 0.70
    mmseqs_sensitivity   = 7.5
    mmseqs_cluster_mode  = 0

    // DIAMOND/MCL parameters
    mcl_evalue           = '1e-5'
    mcl_inflation        = 1.5
    diamond_more_sensitive = true

    // OrthoFinder parameters
    orthofinder_msa      = false   // set true to use -M msa (MSA-based species tree)
}

workDir = "${launchDir}/work/comparative"

process {
    withLabel: 'setup' {
        executor = 'local'
        cpus     = 1
        memory   = '1 GB'
        time     = '30 min'
        queue    = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
        """
    }

    withLabel: 'mmseqs' {
        cpus   = 32
        memory = '128 GB'
        time   = '24 h'
        queue  = 'epyc'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load mmseqs2
        """
    }

    withLabel: 'diamond' {
        cpus   = 32
        memory = '64 GB'
        time   = '24 h'
        queue  = 'epyc'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load diamond
        """
    }

    withLabel: 'mcl' {
        cpus   = 8
        memory = '32 GB'
        time   = '4 h'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load mcl
        """
    }

    withLabel: 'orthofinder' {
        cpus   = 32
        memory = '128 GB'
        time   = '48 h'
        queue  = 'epyc'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load orthofinder
        """
    }

    // Process-specific overrides
    withName: 'MMSEQS_CREATEDB' {
        cpus   = 8
        memory = '32 GB'
        time   = '4 h'
    }
    withName: 'MMSEQS_CREATETSV' {
        cpus   = 4
        memory = '16 GB'
        time   = '2 h'
    }
    withName: 'MCL_PREPARE' {
        cpus   = 1
        memory = '4 GB'
        time   = '1 h'
    }
    withName: 'ORTHOFINDER_PARSE' {
        cpus   = 1
        memory = '4 GB'
        time   = '30 min'
    }
}

trace {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/comparative_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,rss,tag'
}
report {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/comparative_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/comparative_timeline.html"
    overwrite = true
}
