/*
 * interproscan6 profile: interproscan6.nf (runs ebi-pf-team/interproscan6 sub-pipeline).
 *
 * SOURCE: ../../../1KFG/common_annotate/pipeline/nextflow/nextflow.config (interproscan6 profile)
 *         ../../../1KFG/common_annotate/pipeline/nextflow/interproscan6.nf (params block)
 * Last synced: 2026-05-23
 * Changes vs source: params extracted from interproscan6.nf and merged here.
 */

params {
    target              = "${launchDir}/genome_annotation"
    suppress            = ""
    debug               = false
    ips6_version        = "6.0.0"
    ips6_datadir        = "/bigdata/stajichlab/shared/lib/interproscan6_data"
    ips6_interpro       = "latest"
    ips6_goterms        = true
    ips6_pathways       = true
    ips6_applications   = ""
    singularity_cache   = "/bigdata/stajichlab/shared/containers/interproscan6"
}

workDir = "${launchDir}/work/interproscan6"

process {
    withName: 'INTERPROSCAN6_RUN' {
        queue  = 'epyc'
        cpus   = 16
        memory = '64 GB'
        time   = '72h'
    }
}

trace {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/interproscan6_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,rss,tag'
}
report {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/interproscan6_report.html"
    overwrite = true
}
timeline {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/interproscan6_timeline.html"
    overwrite = true
}
