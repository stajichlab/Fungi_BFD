/*
 * Test profile: uses minimal synthetic data from tests/data/.
 * Run with: nextflow run pipeline/nextflow/genome_functional.nf -profile test -stub-run
 */

params {
    samples   = "${projectDir}/tests/data/test_samples.csv"
    pep_dir   = "${projectDir}/tests/data/input"
    outdir    = "${projectDir}/tests/output/function"
    tables    = "${projectDir}/tests/output/tables"
    scripts   = "${launchDir}/scripts"
    n_test    = 0   // test_samples.csv only has 2 rows

    // run all tools so the stub-run exercises the whole graph
    run_pfam      = true
    run_cazy      = true
    run_merops    = true
    run_signalp   = true
    run_tmhmm     = true
    run_targetp   = true
    run_idp       = true
    run_wolfpsort = true
    run_predgpi   = true
}

process {
    // Minimal resources + no module loading for stub-run (no real tools needed).
    // beforeScript = ':' on each label overrides the main config's module loads.
    withLabel: 'pfam'      { cpus = 1; memory = '1 GB'; time = '10 m'; queue = 'short'; beforeScript = ':' }
    withLabel: 'cazy'      { cpus = 1; memory = '1 GB'; time = '10 m'; queue = 'short'; beforeScript = ':' }
    withLabel: 'merops'    { cpus = 1; memory = '1 GB'; time = '10 m'; queue = 'short'; beforeScript = ':' }
    withLabel: 'signalp'   { cpus = 1; memory = '1 GB'; time = '10 m'; queue = 'short'; clusterOptions = ''; beforeScript = ':' }
    withLabel: 'tmhmm'     { cpus = 1; memory = '1 GB'; time = '10 m'; queue = 'short'; beforeScript = ':' }
    withLabel: 'targetp'   { cpus = 1; memory = '1 GB'; time = '10 m'; queue = 'short'; beforeScript = ':' }
    withLabel: 'idp'       { cpus = 1; memory = '1 GB'; time = '10 m'; queue = 'short'; clusterOptions = ''; beforeScript = ':' }
    withLabel: 'wolfpsort' { cpus = 1; memory = '1 GB'; time = '10 m'; queue = 'short'; beforeScript = ':' }
    withLabel: 'predgpi'   { cpus = 1; memory = '1 GB'; time = '10 m'; queue = 'short'; beforeScript = ':' }
    withLabel: 'merge'     { cpus = 1; memory = '1 GB'; time = '10 m'; queue = 'short'; beforeScript = ':' }
}

workDir = "${projectDir}/tests/work"
