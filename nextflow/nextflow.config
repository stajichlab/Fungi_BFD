/*
 * Nextflow configuration for BigFungiData pipelines.
 *
 * Activate a pipeline family with -profile:
 *   -profile BFD           → genome_functional.nf + genome_seqstats.nf
 *   -profile funannotate   → funannotate.nf
 *   -profile interproscan6 → interproscan6.nf
 *
 * Shared params (samples, n_test) live here; everything else is in conf/profile_*.config.
 * Trace/report/timeline files are scoped per-profile so runs never clobber each other.
 */

manifest {
    name            = 'BigFungiData'
    description     = 'Fungal genome annotation and statistics'
    version         = '1.0'
    nextflowVersion = '>=25.10'
}

// ── Shared params ─────────────────────────────────────────────────────────────
params {
    samples = "${launchDir}/samples.csv"
    n_test  = 0
}

// ── SLURM executor (shared by all profiles) ───────────────────────────────────
executor {
    name            = 'slurm'
    queueSize       = 200
    submitRateLimit = '20/1min'
    pollInterval    = '30 sec'
    exitReadTimeout = '10 min'
}

// ── Process defaults ──────────────────────────────────────────────────────────
process {
    shell          = ['/bin/bash', '-l']
    errorStrategy  = { task.attempt < 3 ? 'retry' : 'finish' }
    maxRetries     = 2
    queue          = 'epyc'
    cache          = 'lenient'
    clusterOptions = '-N 1 -n 1'
}

singularity {
    enabled      = false
    autoMounts   = true
    cacheDir     = '/bigdata/stajichlab/shared/lib/singularity_cache'
    envWhitelist = 'SCRATCH'
}

// ── Profiles ──────────────────────────────────────────────────────────────────
profiles {
    BFD           { includeConfig 'conf/profile_BFD.config'           }
    funannotate   { includeConfig 'conf/profile_funannotate.config'   }
    interproscan6 { includeConfig 'conf/profile_interproscan6.config' }
    test          { includeConfig 'conf/test.config'                  }
    stub {
        includeConfig 'conf/test.config'
        params.n_test = 2
    }
}
