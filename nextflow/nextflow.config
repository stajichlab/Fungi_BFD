/*
 * Nextflow configuration for Fungi 5K functional annotation pipeline
 * Targets the UCR HPCC SLURM cluster with module-based software.
 */

manifest {
    name        = 'BigFungiData'
    description = 'Functional annotation of fungal genomes'
    version     = '1.0'
    nextflowVersion = '>=25.10'
}

params {
    samples    = "${launchDir}/samples.csv"
    pep_dir    = "${launchDir}/pep"
    outdir     = "${launchDir}/results/function"
    cds_dir    = "${launchDir}/cds"
    tables     = "${launchDir}/tables"
    gff_dir    = "${launchDir}/gff3"
    genome_dir = "${launchDir}/genome"
    scripts    = "${launchDir}/scripts"

    run_pfam      = true
    run_cazy      = true
    run_merops    = true
    run_signalp   = true
    run_tmhmm     = true
    run_targetp   = true
    run_idp       = true
    run_wolfpsort = true
    run_predgpi   = true

    // pfam_nodes / pfam_tasks: SLURM nodes and MPI tasks for hmmsearch
    // pfam_tasks = 1 → single-node threaded; >1 → MPI (1 master + N-1 workers)
    pfam_nodes    = 1
    pfam_tasks    = 1
    n_test = 0
}

// ── executor ─────────────────────────────────────────────────────────────────
executor {
    name            = 'slurm'
    queueSize       = 200
    submitRateLimit = '10/1min'
    pollInterval    = '30 sec'
    exitReadTimeout = '10 min'
}

// ── process defaults ──────────────────────────────────────────────────────────
process {
    shell          = ['/bin/bash', '-l']
    errorStrategy  = { task.attempt < 1 ? 'retry' : 'finish' }
    maxRetries     = 2
    queue          = 'epyc'
    cache          = 'lenient'
    clusterOptions = '-N 1 -n 1'

    withLabel: 'pfam' {
        cpus           = 8
        memory         = '32 GB'
        time           = '8 h'
        queue          = 'highclock'
        clusterOptions = { params.pfam_tasks > 1
                            ? "-N ${params.pfam_nodes} -n ${params.pfam_tasks} -c 1"
                            : '-N 1 -n 1' }
        beforeScript   = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            if [ ${params.pfam_tasks} -gt 1 ]; then
                module load hmmer/3.4-mpi
            else
                module load hmmer/3.4
            fi
            module load db-pfam
            module load workspace/scratch
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'cazy' {
        cpus         = 16
        memory       = '8 GB'
        time         = '2 h'
        queue        = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load dbcanlight
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'merops' {
        cpus   = 8
        memory = '4 GB'
        time   = '2 h'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load db-merops/124
            module load ncbi-blast/2.16.0+
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'signalp' {
        cpus           = 8
        memory         = '64 GB'
        time           = '4 h'
        queue          = 'exfab'
        clusterOptions = '-N 1 -n 1 --gres=gpu:1'
        beforeScript   = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load signalp/6-gpu
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'tmhmm' {
        cpus   = 4
        memory = '8 GB'
        time   = '2 h'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load tmhmm
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'targetp' {
        cpus   = 8
        memory = '16 GB'
        time   = '4 h'
        queue  = 'epyc'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load targetp
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'idp' {
        cpus           = 4
        memory         = '48 GB'
        time           = '8 h'
        queue          = 'exfab'
        clusterOptions = '-N 1 -n 1 --gres=gpu:1'
        beforeScript   = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load aiupred
            module load biopython
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'wolfpsort' {
        cpus   = 4
        memory = '8 GB'
        time   = '2 h'
        queue  = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load wolfpsort
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'predgpi' {
        cpus         = 4
        memory       = '16 GB'
        time         = '4 h'
        queue        = 'epyc'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load predgpi
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }

    withLabel: 'merge' {
        cpus         = 4
        memory       = '24 GB'
        time         = '2 h'
        queue        = 'short'
        beforeScript = """
            source /etc/profile.d/modules.sh 2>/dev/null || true
            export CONDA_NO_PLUGINS=true
            module load miniconda3
            eval "\$(conda shell.bash hook)"
            module load biopython
            export PATH="${projectDir}/bin:\${PATH}"
        """
    }
}

// ── work directory ────────────────────────────────────────────────────────────
workDir = "${launchDir}/work/nextflow_functional"

// ── execution profiles ────────────────────────────────────────────────────────
profiles {
    test {
        includeConfig 'conf/test.config'
    }
    stub {
        includeConfig 'conf/test.config'
        params.n_test = 2
    }
}

// ── trace / report ────────────────────────────────────────────────────────────
trace {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/functional_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,rss,tag'
}

report {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/functional_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/functional_timeline.html"
    overwrite = true
}
