/*
 * Nextflow configuration for Fungi 5K functional annotation pipeline
 * Targets the UCR HPCC SLURM cluster with module-based software.
 */

manifest {
    name        = 'BigFungiData'
    description = 'Functional annotation of fungal genomes'
    version     = '1.0'
    nextflowVersion = '>=25.10'
}

params {
    samples    = "${launchDir}/samples.csv"
    pep_dir    = "${launchDir}/pep"
    outdir     = "${launchDir}/results/function"
    cds_dir    = "${launchDir}/cds"
    tables     = "${launchDir}/tables"
    gff_dir    = "${launchDir}/gff3"
    genome_dir = "${launchDir}/genome"
    scripts    = "${launchDir}/scripts"

    run_pfam      = true
    run_cazy      = true
    run_merops    = true
    run_signalp   = true
    run_tmhmm     = true
    run_targetp   = true
    run_idp       = true
    run_wolfpsort = true
    run_predgpi   = true

    n_test = 0
}

// ── executor ─────────────────────────────────────────────────────────────────
executor {
    name            = 'slurm'
    queueSize       = 200
    submitRateLimit = '10/1min'
    pollInterval    = '30 sec'
    exitReadTimeout = '10 min'
}

// ── process defaults ──────────────────────────────────────────────────────────
process {
    shell          = ['/bin/bash', '-l']
    errorStrategy  = { task.attempt < 3 ? 'retry' : 'finish' }
    maxRetries     = 2
    queue          = 'epyc'
    cache          = 'lenient'
    clusterOptions = '-N 1 -n 1'

    withLabel: 'pfam' {
        cpus   = 16
        memory = '48 GB'
        time   = '8 h'
        queue  = 'epyc'
        beforeScript = '''
            module load hmmer/3.4
            module load db-pfam
            module load workspace/scratch
        '''
    }

    withLabel: 'cazy' {
        cpus         = 16
        memory       = '8 GB'
        time         = '2 h'
        queue        = 'short'
        beforeScript = '''
            export CONDA_NO_PLUGINS=true
            module load dbcanlight
        '''
    }

    withLabel: 'merops' {
        cpus   = 8
        memory = '4 GB'
        time   = '2 h'
        queue  = 'short'
        beforeScript = '''
            module load db-merops/124
            module load ncbi-blast/2.16.0+
        '''
    }

    withLabel: 'signalp' {
        cpus           = 8
        memory         = '64 GB'
        time           = '4 h'
        queue          = 'exfab'
        clusterOptions = '-N 1 -n 1 --gres=gpu:1'
        beforeScript   = '''
            export CONDA_NO_PLUGINS=true
            module load signalp/6-gpu
        '''
    }

    withLabel: 'tmhmm' {
        cpus   = 4
        memory = '8 GB'
        time   = '2 h'
        queue  = 'short'
        beforeScript = 'module load tmhmm'
    }

    withLabel: 'targetp' {
        cpus   = 8
        memory = '16 GB'
        time   = '4 h'
        queue  = 'epyc'
        beforeScript = 'module load targetp'
    }

    withLabel: 'idp' {
        cpus           = 4
        memory         = '48 GB'
        time           = '8 h'
        queue          = 'exfab'
        clusterOptions = '-N 1 -n 1 --gres=gpu:1'
        beforeScript   = '''
            export CONDA_NO_PLUGINS=true
            module load aiupred
            module load biopython
        '''
    }

    withLabel: 'wolfpsort' {
        cpus   = 4
        memory = '8 GB'
        time   = '2 h'
        queue  = 'short'
        beforeScript = 'module load wolfpsort'
    }

    withLabel: 'predgpi' {
        cpus         = 4
        memory       = '16 GB'
        time         = '4 h'
        queue        = 'epyc'
        beforeScript = '''
            export CONDA_NO_PLUGINS=true
            module load predgpi
        '''
    }

    withLabel: 'merge' {
        cpus         = 4
        memory       = '24 GB'
        time         = '2 h'
        queue        = 'short'
        beforeScript = '''
            export CONDA_NO_PLUGINS=true
            module load biopython
        '''
    }
}

// ── work directory ────────────────────────────────────────────────────────────
workDir = "${launchDir}/work/nextflow_functional"

// ── execution profiles ────────────────────────────────────────────────────────
profiles {
    test {
        includeConfig 'conf/test.config'
    }
    stub {
        includeConfig 'conf/test.config'
        params.n_test = 2
    }
}

// ── trace / report ────────────────────────────────────────────────────────────
trace {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/functional_trace.txt"
    overwrite = true
    fields    = 'task_id,name,status,exit,realtime,%cpu,rss,tag'
}

report {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/functional_report.html"
    overwrite = true
}

timeline {
    enabled   = true
    file      = "${launchDir}/logs/nextflow/functional_timeline.html"
    overwrite = true
}
